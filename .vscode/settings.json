{
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/node_modules": true,
    "**/.wwebjs_auth": true,
    "**/.wwebjs_cache": true,
    "**/.next": true,
    "**/.cache": true,
    "**/.vscode": false
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/.wwebjs_auth": true,
    "**/.wwebjs_cache": true,
    "**/.next": true,
    "**/.cache": true
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/.wwebjs_auth/**": true,
    "**/.wwebjs_cache/**": true,
    "**/.next/**": true,
    "**/.cache/**": true
  }
}
